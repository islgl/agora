# Node
node_modules
dist
dist-ssr
*.local

# Homepage verification screenshots (~1MB each, regenerated on demand)
_shots/

# Secrets — never commit
.env
.env.*
!.env.example

# TypeScript incremental build info
*.tsbuildinfo

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Rust / Cargo
src-tauri/target/

# Tauri generated files
src-tauri/gen/

# Editor
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# macOS
.DS_Store
**/.DS_Store

# Claude Code — commit shared config/hooks, ignore personal overrides
.claude/settings.local.json

# Internal design docs stay local only; the deployed homepage is whitelisted.
docs/*
!docs/index.html
!docs/assets/
!docs/assets/**
!docs/.nojekyll
!docs/CNAME
